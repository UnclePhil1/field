{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    { "source": "/match/:id", "destination": "/api/share" },
    { "source": "/replay/:id", "destination": "/api/share" },
    { "source": "/tournaments/:id", "destination": "/api/share" },
    { "source": "/brag", "destination": "/api/share" },
    { "source": "/score", "destination": "/api/share" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
